# Copy to .env.local (never commit .env.local)

# Google Sheet — Web App URL from Apps Script deploy (see scripts/google-sheets-apps-script.gs)
GOOGLE_SHEET_WEB_APP_URL=

# Same value as Script Property SECRET in Apps Script (long random string).
# No spaces around =. Avoid wrapping in quotes unless the secret itself contains spaces.
GOOGLE_SHEET_SECRET=
